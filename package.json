{
  "name": "prod-ready-backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "node ./tests/test.js",
    "prepare": "husky",
    "dev": "nodemon ./src/server.ts",
    "start": "node ./dist/server.js",
    "dist": "pnpm exec tsc",
    "lint": "eslint src ",
    "lint:fix": "eslint src --fix" ,
    "format:check":"prettier  --check",
    "format:fix": "prettier  --write"

  },
  "keywords": [],
  "lint-staged": {
    "*.{ts,tsx}": [
      "pnpm lint:fix",
      "pnpm format:fix"
    ]
  },
  "author": "",
  "license": "ISC",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.6.0",
      "onFail": "download"
    }
  },
  "type": "module",
  "dependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.3",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.4",
    "ts-node": "^10.9.2",
    "typescript-eslint": "^8.61.1"
  }
}
