{
  "name": "prod-ready-backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "node ./tests/test.js",
    "prepare": "husky",
    "dev": "cross-env NODE_ENV=development nodemon ./src/server.ts",
    "start": "cross-env NODE_ENV=production nodemon ./dist/server.js",
    "dist": "pnpm exec tsc",
    "lint": "eslint src ",
    "lint:fix": "eslint src --fix",
    "format:check": "prettier  --check",
    "format:fix": "prettier  --write",
    "type": "module"
  },
  "keywords": [],
  "lint-staged": {
    "*.{ts,tsx}": [
      "pnpm lint:fix",
      "pnpm format:fix"
    ]
  },
  "author": "",
  "license": "ISC",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.6.0",
      "onFail": "download"
    }
  },
  "type": "module",
  "dependencies": {
    "@types/express": "^5.0.6",
    "colorette": "^2.0.20",
    "cors": "^2.8.6",
    "dotenv-flow": "^4.1.0",
    "express": "^5.2.1",
    "helmet": "^8.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "npm-check-updates": "^22.2.3",
    "source-map-support": "^0.5.21",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/node": "^26.0.0",
    "@types/source-map-support": "^0.5.10",
    "cross-env": "^10.1.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.4",
    "ts-node": "^10.9.2",
    "typescript-eslint": "^8.61.1"
  }
